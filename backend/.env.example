# --- Django Configuration ---
SECRET_KEY=your-super-secret-key-goes-here
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development

# --- Database ---
# For local dev, SQLite is used by default if DATABASE_URL is empty
# For production (PostgreSQL): postgres://user:pass@host:5432/dbname
DATABASE_URL=

# --- Production Settings ---
RENDER_EXTERNAL_HOSTNAME=restaurant-api.onrender.com
CORS_ALLOWED_ORIGIN=https://restaurant-site.vercel.app
ADMIN_PASSWORD=your-secure-admin-password

# --- Twilio WhatsApp API ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Twilio Sandbox number: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# The restaurant owner's WhatsApp number (must be registered in Twilio Sandbox)
OWNER_WHATSAPP_NUMBER=9876543210

# --- Razorpay Payment Gateway ---
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
